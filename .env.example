# Optional. Enables Cloudflare Web Analytics in production builds.
# Leave empty locally.
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Optional. Used by scripts/weekly-analytics-digest.mjs and GitHub Actions.
# Store real values in GitHub Secrets/Variables, not in the repository.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WEB_ANALYTICS_HOSTNAME=karavanov.fi
SLACK_WEBHOOK_URL=
WEEKLY_ANALYTICS_LOOKBACK_DAYS=7
